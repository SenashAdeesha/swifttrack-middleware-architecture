# SwiftTrack Frontend Environment Variables

# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable the following APIs:
# - Maps JavaScript API
# - Geocoding API
# - Places API (optional, for autocomplete)
VITE_GOOGLE_MAPS_API_KEY=AIzaSyBqHwJGmEk2G4vKXGXk3FqH_4RJWOg8i-M

# API Base URL (default: http://localhost:5002/api)
VITE_API_BASE_URL=http://localhost:5002/api

# WebSocket URL (default: http://localhost:5006)
VITE_WEBSOCKET_URL=http://localhost:5006
